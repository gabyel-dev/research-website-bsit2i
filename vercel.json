{
  "rewrites": [
    {
      "source": "/health/:path*",
      "destination": "https://techitik-server.onrender.com/health/:path*"
    },
    {
      "source": "/apu/auth/:path*",
      "destination": "https://techitik-server.onrender.com/api/auth/:path*"
    },
    {
      "source": "/apu/researches/:path*",
      "destination": "https://techitik-server.onrender.com/api/researches/:path*"
    },

    {
      "source": "/api/users/:path*",
      "destination": "https://techitik-server.onrender.com/api/users/:path*"
    },

    {
      "source": "/attempt/:path*",
      "destination": "https://techitik-server.onrender.com/attempt/:path*"
    },

    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
